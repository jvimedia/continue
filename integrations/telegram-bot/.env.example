# Token from @BotFather (see README.md for how to create a bot).
TELEGRAM_BOT_TOKEN=

# Base URL of the Continue Chat API server exposed by the VS Code extension.
# Default matches the extension's default `continue.chatApi.port` (65432)
# bound to `continue.chatApi.host` (127.0.0.1).
CONTINUE_API_URL=http://127.0.0.1:65432

# Token shown by VS Code when the Chat API server starts (or via the
# "Continue: Show Chat API Token" command). See
# docs/guides/chat-streaming-api.mdx in the continue repo for details.
CONTINUE_API_TOKEN=

# Comma-separated list of Telegram chat IDs allowed to talk to the bot.
# Messages from any other chat are ignored (and logged). See README.md for
# how to find your chat ID.
ALLOWED_TELEGRAM_CHAT_IDS=
